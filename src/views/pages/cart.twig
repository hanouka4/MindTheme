{#
| Variable                                          | Type                | Description                                                    |
|---------------------------------------------------|---------------------|----------------------------------------------------------------|
| cart                                              | Cart                |                                                                |
#}

{% extends "layouts.master" %}
{% block content %}

<!-- HERO -->
<section class="page-hero">
  <div class="page-hero-inner">
    <div class="eyebrow">CHECKOUT  ·  {{ trans('blocks.header.cart') }}</div>
    <h1>{{ trans('pages.cart.complete_order')|replace({' ': '<br>'})|raw }}<br><span class="accent">{{ trans('pages.cart.final_total') }}.</span></h1>
    <p>Select what you need. Bundle and save automatically.</p>
  </div>
</section>

<div class="cart-wrap">
    <!-- LEFT: Products -->
    <div class="cart-products">
        <div>
            <div class="section-label">PRODUCTS  ·  {{ trans('pages.products.title') }}</div>
            <h2 class="section-title">Edition 01 — Design AI.</h2>
        </div>

        {% hook 'cart:items.start' %}

        {% for item in cart.items %}
            <form onchange="salla.form.onChange('cart.updateItem', event)" id="item-{{ item.id }}">
                <section class="cart-item-custom">
                    <input type="hidden" name="id" value="{{ item.id }}">
                    
                    <div class="num">{{ loop.index|format_number({minimum_integer_digits: 2}) }}</div>
                    
                    <div class="info">
                        <h3><a href="{{ item.url }}">{{ item.product_name }}</a></h3>
                        <div class="en">{{ item.product_name_en|default(item.product_name) }}</div>
                        <div class="meta">
                            {% if item.weight_label %}
                                {{ item.weight_label }} · 
                            {% endif %}
                            {{ item.type|upper }}
                        </div>
                        
                        {# Options if any #}
                        {% include 'pages.partials.product.options' with {product:item} %}
                    </div>

                    <div class="price-box">
                        <div class="amt">{{ item.total|money_without_currency }}</div>
                        <span class="ccy">{{ store.currency }}</span>
                    </div>

                    <div class="actions" style="display: flex; flex-direction: column; gap: 10px; align-items: flex-end;">
                        <salla-button type="button" shape="icon" size="small" color="danger" 
                                onclick="salla.cart.deleteItem('{{ item.id }}').then(() => document.querySelector('#item-{{ item.id }}').remove())"
                                aria-label="Remove">
                            <i class="sicon-cancel"></i>
                        </salla-button>
                        
                        {% if not item.is_hidden_quantity %}
                            <salla-quantity-input cart-item-id="{{ item.id }}" max="{{ item.max_quantity }}"
                                value="{{ item.quantity }}" name="quantity" size="small">
                            </salla-quantity-input>
                        {% endif %}
                    </div>
                </section>
            </form>
        {% else %}
            <div class="no-content-placeholder">
                <i class="sicon-shopping-bag icon"></i>
                <p>{{ trans('pages.cart.empty_cart') }}</p>
                <a href="{{ link('/') }}" class="btn btn--outline-primary btn--rounded-full">{{ trans('common.elements.back_home') }}</a>
            </div>
        {% endfor %}

        {# Workshop info banner — matches target design flow #}
        <a href="{{ link('products') }}" class="workshop-banner" style="display:block; background:var(--ink); color:var(--cream); padding:24px 28px; text-decoration:none; transition:all .2s; border:1px solid var(--ink); margin-top: 20px;">
          <div style="display:flex; justify-content:space-between; align-items:center; gap:16px; flex-wrap:wrap;">
            <div>
              <div style="font-family:'JetBrains Mono', monospace; font-size:10px; color:var(--coral); letter-spacing:0.25em; font-weight:700; margin-bottom:8px;">WORKSHOP  ·  مسار منفصل</div>
              <h3 style="font-size:18px; font-weight:700; color:var(--cream); margin-bottom:4px;">الورشة الحضورية — التقديم بالدعوة</h3>
              <p style="font-family:'Cormorant Garamond', serif; font-style:italic; font-size:14px; color:var(--tan);">للورشة الحضوريّة تقديم منفصل عبر صفحة الورشة.</p>
            </div>
            <div style="font-family:'JetBrains Mono', monospace; font-size:11px; color:var(--coral); letter-spacing:0.18em; font-weight:700;">صفحة الورشة  ←</div>
          </div>
        </a>

        {% hook 'cart:items.end' %}
    </div>

    <!-- RIGHT: Summary -->
    {% if cart.items|length %}
        <aside class="cart-summary-custom">
            <h3>ORDER SUMMARY  ·  {{ trans('pages.cart.summary') }}</h3>
            <div class="total-title">الطلب.</div>

            <div class="summary-list">
                <div class="summary-line">
                    <span class="label">{{ trans('pages.cart.items_total') }}</span>
                    <span class="val">{{ cart.sub_total|money }}</span>
                </div>

                {% if cart.total_discount %}
                    <div class="summary-line" style="color: var(--coral);">
                        <span class="label">{{ trans('pages.cart.discount') }}</span>
                        <span class="val">- {{ cart.total_discount|money }}</span>
                    </div>
                {% endif %}

                {% if cart.tax_amount %}
                    <div class="summary-line">
                        <span class="label">{{ trans('pages.cart.VAT_tax_amount') }}</span>
                        <span class="val">{{ cart.tax_amount|money }}</span>
                    </div>
                {% endif %}

                {% if cart.has_shipping %}
                    <div class="summary-line">
                        <span class="label">{{ trans('pages.cart.shipping_cost') }}</span>
                        <span class="val">{{ cart.real_shipping_cost|money }}</span>
                    </div>
                {% endif %}
            </div>

            {% if store.settings.cart.apply_coupon_enabled %}
                <div style="margin-bottom: 24px;">
                    <salla-cart-coupons></salla-cart-coupons>
                </div>
            {% endif %}

            <div class="total-row-custom">
                <span class="label">TOTAL  ·  {{ trans('pages.cart.final_total') }}</span>
                <span><span class="amt">{{ cart.total|money_without_currency }}</span><span class="ccy">{{ store.currency }}</span></span>
            </div>

            <div class="cart-submit-wrap">
                {% hook 'cart:submit.start' %}
                <salla-button id="cart-submit" loader-position="center" width="wide" class="cart-submit-btn">
                    {{ trans('pages.cart.complete_order') }}  ←
                </salla-button>
                {% hook 'cart:submit.end' %}
            </div>

            <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 13px; color: var(--tan); margin-top: 18px; line-height: 1.5; text-align: center;">
              الدفع نهائي وغير قابل للاسترداد بعد التسليم.
            </p>
        </aside>
    {% endif %}
</div>

<!-- TERMS BOX -->
<div class="terms-box">
  <div class="terms-col">
    <h4>POLICY  ·  الشراء</h4>
    <h5>الدفع نهائي بعد التسليم.</h5>
    <p>الأدلّة منتجات رقميّة تُسلَّم فور تأكيد الدفع. لا يُسمح بالاسترداد كلياً أو جزئياً بعد إرسال الملف.</p>
  </div>
  <div class="terms-col">
    <h4>POLICY  ·  الترخيص</h4>
    <h5>استخدام شخصيّ.</h5>
    <p>الأدلّة محفوظة الحقوق لـ MiND Academy. الاستخدام مقصور على المشتري الأصليّ، ولا يُسمح بمشاركة الملف أو إعادة بيعه.</p>
  </div>
</div>

{% endblock %}

{% block scripts %}
    <script defer src="{{ 'checkout.js' | asset }}"></script>
{% endblock %}
