{#
| Variable                               | Type                        | Description                                                            |
|----------------------------------------|-----------------------------|------------------------------------------------------------------------|
| product                                | Product                     |                                                                        |
#}
{% extends "layouts.master" %}
{% block content %}

<div class="product-hero">
    <div class="product-hero-inner">
        <div class="product-details-custom">
            <div class="section-label" style="margin-bottom: 28px;">
                {{ product.category.name|upper }} · {{ product.sku|default('EDITION 01') }}
            </div>
            
            <h1 class="text-gray-800">{{ product.name }}</h1>
            
            {% if product.subtitle %}
                <p class="subtitle">{{ product.subtitle }}</p>
            {% endif %}

            <div class="product-price-row">
                <span class="amount">{{ product.price|money }}</span>
                <span style="margin-right: auto; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gray); letter-spacing: 0.18em; font-weight: 700;">
                    {{ product.is_available ? 'AVAILABLE' : 'OUT OF STOCK' }}
                </span>
            </div>

            <div class="product-features-box">
                <h4>WHAT'S INSIDE · المحتوى</h4>
                <div class="article article--main" style="font-size: 15px; color: var(--soft-ink); line-height: 1.6;">
                    {{ product.description|raw }}
                </div>
            </div>

            <form class="form product-form" enctype="multipart/form-data" method="post"
                  onsubmit="return false;" >
                <input type="hidden" name="id" value="{{ product.id }}">

                {% include 'pages.partials.product.options' %}

                {% if not product.is_hidden_quantity %}
                    <div style="margin-bottom: 16px;">
                        <salla-quantity-input max="{{ product.max_quantity }}" value="1" name="quantity"
                          class="border-gray-200"></salla-quantity-input>
                    </div>
                {% endif %}

                <salla-add-product-button
                        {{product.can_quick_buy ? 'quick-buy' : ''}}
                        amount="{{ product.base_currency_price }}"
                        product-status="{{ product.status }}"
                        product-type="{{ product.type }}"
                        product-id="{{ product.id }}"
                        {{ product.is_require_shipping ? 'required-shipping' : '' }}
                        loader-position="end"
                        width="wide">
                    {{ product.add_to_cart_label }}
                </salla-add-product-button>
            </form>

            <div class="flex rtl:space-x-reverse space-x-3 mt-8">
                <salla-social-share class="inline-flex" aria-label="social share"></salla-social-share>
                <salla-button
                        class="btn--wishlist animated"
                        data-id="{{ product.id }}"
                        onclick="salla.wishlist.toggle('{{ product.id }}')"
                        shape="icon"
                        fill="outline"
                        color="light"
                        aria-label="add to wishlist">
                    <i class="sicon-heart"></i>
                </salla-button>
            </div>
        </div>

        <div class="product-poster-custom">
            <span class="hp-bracket tl"></span>
            <span class="hp-bracket tr"></span>
            <span class="hp-bracket bl"></span>
            <span class="hp-bracket br"></span>
            
            <div class="hp-top">
                <div>PRODUCT</div>
                <div>{{ product.sku|default('EDITION 01') }}</div>
            </div>
            
            <div class="hp-center">
                {% if product.image %}
                    <img src="{{ product.image.url }}" alt="{{ product.image.alt }}" 
                         style="width: 100%; max-height: 300px; object-fit: contain; margin-bottom: 20px;">
                {% endif %}
                <div class="pre">design ai</div>
                <div class="stack">
                    <span class="num">{{ loop.index|default('01') }}</span>
                </div>
                <div class="word">PLAYBOOK</div>
            </div>
            
            <div style="text-align: right;">
                <div style="width: 30px; height: 1px; background: var(--coral); margin-bottom: 12px; margin-right: auto;"></div>
                <div style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--cream); line-height: 1.4;">
                    «الذي يبني النظام<br>يقود السوق».
                </div>
            </div>
        </div>
    </div>
</div>

{# Similar Products Area #}
<div class="container" style="padding-top: 80px; padding-bottom: 80px;">
    <salla-products-slider source="related" source-value="{{product.id}}" block-title="{{trans('pages.products.similar_products')}}" display-all-url></salla-products-slider>
</div>

  <div style="display: none !important;">
    <salla-metadata></salla-metadata>
    <salla-gifting></salla-gifting>
    <salla-installment></salla-installment>
    <salla-quick-order></salla-quick-order>
  </div>
{% endblock %}

{% block scripts %}
    <script defer src="{{ 'product.js' | asset }}"></script>
{% endblock %}
