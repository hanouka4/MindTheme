{#
| Variable         | Type       | Description                                                         |
|------------------|------------|---------------------------------------------------------------------|
| page             | object     |                                                                     |
| page.title       | string     | *could be html                                                      |
| page.slug        | string     | ex: "cat.show"                                                      |
#}
{% extends "layouts.master" %}
{% block content %}

<!-- HERO -->
<section class="page-hero" style="background: var(--ink); color: var(--cream); padding: 120px 40px 80px; border-bottom: 0.5px solid var(--hairline);">
  <div class="container" style="max-width: 1280px; margin: 0 auto;">
    <div style="max-width: 800px;">
      <div class="eyebrow" style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--coral); letter-spacing: 0.25em; font-weight: 700; margin-bottom: 24px;">EDITION 01  ·  PLAYBOOK SERIES</div>
      <h1 style="font-size: clamp(48px, 6vw, 84px); font-weight: 800; line-height: 1.05; margin-bottom: 24px;">الأدلّة<br><span style="color: var(--coral);">التطبيقيّة.</span></h1>
      <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 24px; color: var(--tan); margin-bottom: 40px; max-width: 600px;">
        Not a course. Not a theory. Three playbooks that build your AI-Native interior design studio.
      </p>
    </div>
  </div>
</section>

<!-- MAIN CONTENT -->
<div class="container" style="max-width: 1280px; margin: 80px auto; padding: 0 40px;">
    {% component 'home.playbooks' %}
    
    <div style="margin-top: 100px;">
        {% component 'home.wisdom' %}
    </div>
    
    <div style="margin-top: 100px;">
        {% component 'home.pillars' %}
    </div>
</div>

{% endblock %}
