<footer class="footer" id="contact">
  <div class="footer-inner">
    <div>
      <div class="logo" style="margin-bottom:24px;">
        <span class="logo-dot"></span>
        <span class="logo-text" style="color:var(--cream);">MiND <span class="logo-academy">· Academy</span></span>
      </div>
      <p style="color:var(--tan); font-style:italic; font-family:'Cormorant Garamond', serif; font-size:18px; max-width:340px; line-height:1.5;">
        {{ store.description|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw|default('Studio of AI-Native Interior Design. Riyadh, 2026.') }}
      </p>
    </div>
    <div>
      <h4>ADMISSION · للحجز</h4>
      <a href="mailto:{{ store.contacts.email }}">{{ store.contacts.email }}</a>
      <a href="tel:{{ store.contacts.mobile }}">{{ store.contacts.mobile }}</a>
      <a href="{{ store.url }}">{{ store.url|replace({'https://': '', 'http://': ''}) }}</a>
    </div>
    <div>
      <h4>EXPLORE</h4>
      <salla-menu source="footer"></salla-menu>
    </div>
  </div>
  <div class="footer-bottom">
    MIND ACADEMY · DESIGN AI · EDITION 01 / 2026 · {{ store.city|default('RIYADH')|upper }}
  </div>
</footer>
