{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
| products        | Products[] | List of products               |
#}
<section class="playbooks" style="padding: 100px 0; background: {{ component.bg_color|default('transparent') }};">
  <div class="container" style="max-width: 1280px; margin: 0 auto; padding: 0 40px;">
    
    <h2 class="section-title" style="line-height: 1.1; margin-bottom: 24px; font-weight: 800;
         color: {{ component.title_color|default('#1A1A1A') }}; 
         font-size: {{ component.title_size|default('40px') }}; 
         text-align: {{ component.title_align|default('start') }};">
      {{ component.title|default('مناهج مكثّفة<br>للمصمّم الـ AI-Native.')|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw }}
    </h2>
    
    <p style="line-height:1.7; margin-bottom: 40px; max-width:680px;
         color: {{ component.desc_color|default('#2E2E2E') }}; 
         font-size: {{ component.desc_size|default('17px') }}; 
         text-align: {{ component.desc_align|default('start') }};">
      {{ component.description|default('كل Playbook مدرسة قائمة بذاتها — منهجية مكتملة، أدوات مختارة بعناية، Prompts جاهزة، Case Study حقيقية، وملاحق مرجعية. تُستخدم بشكل مستقل أو كسلسلة متكاملة.')|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw }}
    </p>
    
    <div class="playbooks-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
      {% set default_cards = [
        { 'cards.num': '01', 'cards.title': 'كيف تعمل المخطط بـ AI', 'cards.label': 'How to Build a Floor Plan with AI', 'cards.desc': 'منهجية متكاملة لتحويل البريف إلى مخطط معتمد — في خمس ساعات بدلاً من ثلاثين. Case Study حقيقية، أدوات مختارة، وقوالب جاهزة للنسخ.', 'cards.price': '560', 'cards.currency': 'ر.س', 'cards.edition': 'EDITION 01', 'cards.status': 'AVAILABLE' },
        { 'cards.num': '02', 'cards.title': 'كيف تعمل الرندر بـ AI', 'cards.label': 'How to Build a Render with AI', 'cards.desc': 'من النموذج إلى رندر فوتوغرافي بجودة احترافية — ليس صورة واحدة، بل سرديّة متسلسلة تُغلق العقد قبل الاجتماع.', 'cards.price': '560', 'cards.currency': 'ر.س', 'cards.edition': 'EDITION 01', 'cards.status': 'AVAILABLE' },
        { 'cards.num': '03', 'cards.title': 'كيف تبني استوديو AI', 'cards.label': 'How to Build Your AI Studio', 'cards.desc': 'نظام تشغيليّ متكامل لاستوديو يعمل وأنت نائم — من نموذج التشغيل إلى النظام التقنيّ إلى الإطار التجاري.', 'cards.price': '990', 'cards.currency': 'ر.س', 'cards.edition': 'EDITION 01', 'cards.status': 'AVAILABLE' }
      ] %}
      
      {% set cards = (component.cards and component.cards|length > 0 and component.cards[0]['cards.title']) ? component.cards : default_cards %}
      
      {% for card in cards %}
        {% set card_url = card['cards.url']|default('') %}
        {% if card_url %}
        <a href="{{ card_url }}" class="playbook-card" style="text-decoration: none; color: inherit; display: block; cursor: pointer;">
        {% else %}
        <div class="playbook-card" style="text-decoration: none; color: inherit; display: block;">
        {% endif %}
          <div class="playbook-num">{{ card['cards.num'] }}</div>
          <h3>{{ card['cards.title'] }}</h3>
          <p class="en">{{ card['cards.label'] }}</p>
          <p>{{ card['cards.desc'] }}</p>
          <div class="playbook-price"><span class="amount">{{ card['cards.price'] }}</span><span class="currency">{{ card['cards.currency'] }}</span></div>
          <div class="playbook-meta">
            <span>{{ card['cards.edition'] }}</span>
            <strong>{{ card['cards.status'] }}</strong>
          </div>
        {% if card_url %}
        </a>
        {% else %}
        </div>
        {% endif %}
      {% endfor %}
    </div>

    <div style="margin-top:60px; padding:40px 48px; border-right:4px solid var(--coral); display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:24px;
         background: {{ component.banner_bg|default('#EFE3D5') }};">
      <div>
        <div class="section-label" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--coral); letter-spacing: 0.25em; font-weight: 700; margin-bottom: 14px;">FULL SERIES · السلسلة الكاملة</div>
        <h3 style="font-weight:800; color: {{ component.banner_title_color|default('#1A1A1A') }}; font-size: {{ component.banner_title_size|default('24px') }}; text-align: {{ component.banner_title_align|default('start') }};">
          {{ component.banner_title|default('الـ 3 Playbooks مجتمعة — للمصمّم الذي يبني وحده') }}
        </h3>
        <p style="font-size:14px; color:var(--soft-ink); line-height:1.7; margin-top:12px;">هل تفضّل التطبيق بقيادة فريق MiND؟ الورشة الحضوريّة تشمل الأدلّة الثلاث مجاناً.</p>
      </div>
      <a href="{{ component.banner_url|default(link('products')) }}" class="btn btn-primary" style="display: inline-block; padding: 18px 36px; font-weight: 700; font-size: 14px; transition: all .2s; border: 1px solid transparent; background: var(--ink); color: var(--cream);">للاستفسار  ←</a>
    </div>
  </div>
</section>
