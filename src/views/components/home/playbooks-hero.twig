{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="hero" style="background: {{ component.bg_color|default('var(--cream)') }}; border-bottom: 0.5px solid var(--hairline); padding: 120px 40px 80px;">
  <div class="hero-inner" style="max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 80px; align-items: center;">
    <div style="text-align: {{ component.title_align|default('start') }};">
      <div class="eyebrow" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--coral); letter-spacing: 0.25em; font-weight: 700; margin-bottom: 28px;">
        {{ component.label|default('EDITION 01  ·  PLAYBOOK SERIES') }}
      </div>
      
      <div class="hero-rule" style="width: 60px; height: 2px; background: var(--coral); margin-bottom: 28px;
           {{ component.title_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.title_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}"></div>
      
      <h1 style="font-size: clamp(48px, 6.4vw, 92px); font-weight: 700; line-height: 1.05; margin-bottom: 18px; color: {{ component.title_color|default('var(--ink)') }};">
        {{ component.title|default('الأدلّة<br><span class="accent">التطبيقيّة.</span>')|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw }}
      </h1>

      <p class="hero-tag" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 22px; color: var(--warm-tan); margin-bottom: 28px; direction: ltr; text-align: left;">
        {{ component.tagline|default('Not a course. Not a theory. Three playbooks that build your AI-Native interior design studio.') }}
      </p>

      <div class="hero-quote" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 22px; line-height: 1.5; color: var(--ink); border-right: 2px solid var(--coral); padding-right: 20px; margin-bottom: 36px; max-width: 540px;">
        {{ component.quote|default('«المصمم الذي لا يملك نظاماً هو مصمم يبيع وقته. المصمم الذي يملك نظاماً هو مصمم يبيع نتيجته».') }}
      </div>

      <div class="hero-meta" style="display: flex; flex-wrap: wrap; gap: 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--warm-tan); letter-spacing: 0.18em; font-weight: 700; margin-bottom: 36px;">
        <span>FORMAT <strong>PDF / VAULT</strong></span>
        <span>EDITION <strong>01 / 2026</strong></span>
        <span>ACCESS <strong>LIFETIME</strong></span>
      </div>

      <div class="cta-row" style="display: flex; gap: 14px; flex-wrap: wrap;">
        <a href="#products" class="btn btn-primary" style="background: var(--ink); color: var(--cream); padding: 18px 36px; font-weight: 700; text-decoration: none;">
          {{ component.btn_text|default('اقتنِ السلسلة الكاملة  ←') }}
        </a>
      </div>
    </div>

    <div class="hero-poster" style="background: var(--ink); color: var(--cream); padding: 50px 44px; aspect-ratio: 1; display: flex; flex-direction: column; justify-content: space-between; position: relative;">
      <span class="hp-bracket tl" style="position: absolute; width: 26px; height: 26px; top: 16px; left: 16px; border-top: 1.5px solid var(--coral); border-left: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket tr" style="position: absolute; width: 26px; height: 26px; top: 16px; right: 16px; border-top: 1.5px solid var(--coral); border-right: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket bl" style="position: absolute; width: 26px; height: 26px; bottom: 16px; left: 16px; border-bottom: 1.5px solid var(--coral); border-left: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket br" style="position: absolute; width: 26px; height: 26px; bottom: 16px; right: 16px; border-bottom: 1.5px solid var(--coral); border-right: 1.5px solid var(--coral);"></span>

      <div class="hp-top" style="display: flex; justify-content: space-between; align-items: flex-start; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--coral); letter-spacing: 0.2em; font-weight: 700;">
        <div>EDITION 01</div>
        <div>PLAYBOOKS</div>
      </div>

      <div class="hp-center" style="text-align: center;">
        <div class="pre" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 20px; color: var(--tan); margin-bottom: 8px;">design ai</div>
        <div class="stack" style="display: flex; justify-content: center; gap: 18px; align-items: baseline;">
          <span class="num" style="font-size: clamp(72px, 9vw, 130px); font-weight: 900; color: var(--coral); line-height: 0.85; letter-spacing: -0.04em;">01</span>
        </div>
        <div class="word" style="font-family: -apple-system, sans-serif; font-size: clamp(28px, 3vw, 40px); font-weight: 300; color: var(--cream); letter-spacing: 0.04em; margin-top: 6px;">SERIES</div>
      </div>

      <div class="hp-bottom" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--cream); text-align: right; line-height: 1.4;">
        <div class="hp-rule" style="width: 30px; height: 1px; background: var(--coral); margin-bottom: 12px; margin-right: auto;"></div>
        «الذي يبني النظام<br>يقود السوق».
      </div>
    </div>
  </div>
</section>
