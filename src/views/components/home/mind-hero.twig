{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="hero" style="background: {{ component.bg_color|default('var(--cream)') }};">
  <div class="hero-inner">
    <div style="text-align: {{ component.title_align|default('start') }};">
      
      <div class="hero-label" style="color: {{ component.label_color|default('var(--coral)') }}; 
           font-size: {{ component.label_size|default('11px') }}; 
           text-align: {{ component.label_align|default('start') }};">
        {{ component.label|default('DESIGN AI ACADEMY · 2026') }}
      </div>

      <div class="hero-rule" style="background: {{ component.accent_color|default('var(--coral)') }}; 
           {{ component.title_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.title_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}"></div>
      
      <h1 style="color: {{ component.title_color|default('var(--ink)') }}; 
           font-size: {{ component.title_size|default('64px') }}; 
           text-align: {{ component.title_align|default('start') }};">
        {{ component.title|default('بناء الاستوديو<br><span class="accent">التصميمي.</span>')|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw }}
      </h1>

      <p class="hero-tagline" style="color: {{ component.tagline_color|default('var(--warm-tan)') }}; 
           font-size: {{ component.tagline_size|default('22px') }}; 
           text-align: {{ component.tagline_align|default('start') }};">
        {{ component.tagline|default('Build Your AI-Native Interior Design Studio.') }}
      </p>

      <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; color: {{ component.quote_color|default('var(--ink)') }}; 
           font-size: {{ component.quote_size|default('19px') }}; 
           text-align: {{ component.quote_align|default('start') }}; 
           margin-bottom: 24px; max-width: 540px; line-height: 1.5;
           {{ component.quote_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.quote_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}">
        {{ component.quote|default('«النظام يتفوّق على الموهبة لأن الموهبة تعمل ساعات والنظام يعمل 24/7».') }}
      </p>

      <p class="hero-desc" style="color: {{ component.desc_color|default('var(--soft-ink)') }}; 
           font-size: {{ component.desc_size|default('17px') }}; 
           text-align: {{ component.desc_align|default('start') }};
           {{ component.desc_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.desc_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}">
        {{ component.description|default('نظام كامل للمصمّم الداخلي — مساكن، مقاهي، مكاتب، مطاعم، تجزئة. سلسلة Playbooks مكثّفة + ورشة تطبيقية حضورية، تبني لك استوديو متكامل يعمل بالذكاء الاصطناعي.') }}
      </p>

      <div class="cta-row" style="{{ component.title_align == 'center' ? 'justify-content: center;' : (component.title_align == 'end' ? 'justify-content: flex-end;' : '') }}">
        <a href="{{ component.btn_primary_url|default(link('products')) }}" class="btn btn-primary" style="background: {{ component.btn_primary_bg|default('#1A1A1A') }}; color: {{ component.btn_primary_color|default('#F7EDE3') }};">
          {{ component.btn_primary_text|default('اطّلع على الـ Playbooks  ←') }}
        </a>
        <a href="{{ component.btn_secondary_url|default(link('products')) }}" class="btn btn-secondary" style="background: {{ component.btn_secondary_bg|default('transparent') }}; color: {{ component.btn_secondary_color|default('#1A1A1A') }}; border-color: {{ component.btn_secondary_color|default('#1A1A1A') }};">
          {{ component.btn_secondary_text|default('الورشة الحضورية') }}
        </a>
      </div>
    </div>

    <div class="hero-visual">
      <span class="hv-bracket tl"></span>
      <span class="hv-bracket tr"></span>
      <span class="hv-bracket bl"></span>
      <span class="hv-bracket br"></span>

      <div class="hv-top">
        <div>
          <div class="hero-visual-text">EDITION 01</div>
          <div class="hero-visual-text" style="margin-top:8px; color: var(--cream);">RIYADH · 2026</div>
        </div>
        <div style="text-align:right;">
          <div class="hero-visual-text">PLAYBOOK SERIES</div>
          <div style="font-family:'JetBrains Mono', monospace; font-size:11px; color:var(--coral); letter-spacing:0.25em; margin-top:8px; font-weight:700;">01 · 02 · 03</div>
        </div>
      </div>

      <div class="hv-stack">
        <div class="pre">a studio of</div>
        <div class="word-1">DESIGN</div>
        <div class="word-2">AI</div>
        <div class="word-3">ACADEMY</div>
      </div>

      <div>
        <div class="hv-rule"></div>
        <div class="hv-quote">«النظام يتفوّق<br>على الموهبة».</div>
      </div>
    </div>
  </div>
</section>
