{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="hero" style="background: {{ component.bg_color|default('var(--cream)') }}; padding: 120px 40px 80px; border-bottom: 0.5px solid var(--hairline);">
  <div class="hero-inner" style="max-width: 1280px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
    <div style="text-align: {{ component.title_align|default('start') }};">
      
      <div class="hero-label" style="font-family: 'JetBrains Mono', monospace; letter-spacing: 0.15em; font-weight: 700; margin-bottom: 24px; 
           color: {{ component.label_color|default('var(--coral)') }}; 
           font-size: {{ component.label_size|default('11px') }}; 
           text-align: {{ component.label_align|default('start') }};">
        {{ component.label|default('DESIGN AI ACADEMY · 2026') }}
      </div>

      <div class="hero-rule" style="width: 60px; height: 2px; background: {{ component.accent_color|default('var(--coral)') }}; margin-bottom: 28px; 
           {{ component.title_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.title_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}"></div>
      
      <h1 style="line-height: 1; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 24px;
           color: {{ component.title_color|default('var(--ink)') }}; 
           font-size: {{ component.title_size|default('64px') }}; 
           text-align: {{ component.title_align|default('start') }};">
        {{ component.title|raw|default('بناء الاستوديو<br><span class="accent" style="color:'~component.accent_color|default('var(--coral)')~';">التصميمي.</span>') }}
      </h1>

      <p class="hero-tagline" style="font-weight: 600; margin-bottom: 16px; 
           color: {{ component.tagline_color|default('var(--ink)') }}; 
           font-size: {{ component.tagline_size|default('22px') }}; 
           text-align: {{ component.tagline_align|default('start') }};">
        {{ component.tagline|default('Build Your AI-Native Interior Design Studio.') }}
      </p>

      <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; margin-bottom: 24px; max-width: 540px; line-height: 1.5;
           color: {{ component.quote_color|default('var(--ink)') }}; 
           font-size: {{ component.quote_size|default('19px') }}; 
           text-align: {{ component.quote_align|default('start') }}; 
           {{ component.quote_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.quote_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}">
        {{ component.quote|default('«النظام يتفوّق على الموهبة لأن الموهبة تعمل ساعات والنظام يعمل 24/7».') }}
      </p>

      <p class="hero-desc" style="line-height: 1.6; opacity: 0.85; max-width: 520px; margin-bottom: 40px;
           color: {{ component.desc_color|default('var(--ink)') }}; 
           font-size: {{ component.desc_size|default('17px') }}; 
           text-align: {{ component.desc_align|default('start') }};
           {{ component.desc_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.desc_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}">
        {{ component.description|default('نظام كامل للمصمّم الداخلي — مساكن، مقاهي، مكاتب، مطاعم، تجزئة. سلسلة Playbooks مكثّفة + ورشة تطبيقية حضورية، تبني لك استوديو متكامل يعمل بالذكاء الاصطناعي.') }}
      </p>

      <div class="cta-row" style="display: flex; gap: 16px; flex-wrap: wrap; {{ component.title_align == 'center' ? 'justify-content: center;' : (component.title_align == 'end' ? 'justify-content: flex-end;' : '') }}">
        <a href="{{ link('products') }}" class="btn btn-primary" style="display: inline-block; padding: 18px 36px; font-weight: 700; font-size: 14px; transition: all .2s; border: 1px solid transparent; 
           background: {{ component.btn_primary_bg|default('#1A1A1A') }}; 
           color: {{ component.btn_primary_color|default('#F7EDE3') }};">
          {{ component.btn_primary_text|default('اطّلع على الـ Playbooks  ←') }}
        </a>
        <a href="{{ link('products') }}" class="btn btn-secondary" style="display: inline-block; padding: 18px 36px; font-weight: 700; font-size: 14px; transition: all .2s; border: 1px solid var(--hairline); 
           background: {{ component.btn_secondary_bg|default('transparent') }}; 
           color: {{ component.btn_secondary_color|default('#1A1A1A') }};">
          {{ component.btn_secondary_text|default('الورشة الحضورية') }}
        </a>
      </div>
    </div>

    <div class="hero-visual" style="position: relative; height: 100%; min-height: 500px; display: flex; flex-direction: column; justify-content: space-between; padding: 40px;">
      <span class="hv-bracket tl" style="position: absolute; width: 16px; height: 16px; border: 1px solid var(--gray); top: 0; left: 0; border-right: none; border-bottom: none;"></span>
      <span class="hv-bracket tr" style="position: absolute; width: 16px; height: 16px; border: 1px solid var(--gray); top: 0; right: 0; border-left: none; border-bottom: none;"></span>
      <span class="hv-bracket bl" style="position: absolute; width: 16px; height: 16px; border: 1px solid var(--gray); bottom: 0; left: 0; border-right: none; border-top: none;"></span>
      <span class="hv-bracket br" style="position: absolute; width: 16px; height: 16px; border: 1px solid var(--gray); bottom: 0; right: 0; border-left: none; border-top: none;"></span>

      <div class="hv-top" style="display: flex; justify-content: space-between; align-items: flex-start; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--gray); letter-spacing: 0.1em; line-height: 1.4;">
        <div>
          <div class="hero-visual-text">EDITION 01</div>
          <div class="hero-visual-text" style="margin-top:8px; color: {{ component.bg_color|default('var(--cream)') }};">RIYADH · 2026</div>
        </div>
        <div style="text-align:right;">
          <div class="hero-visual-text">PLAYBOOK SERIES</div>
          <div style="font-family:'JetBrains Mono', monospace; font-size:11px; color:{{ component.accent_color|default('var(--coral)') }}; letter-spacing:0.25em; margin-top:8px; font-weight:700;">01 · 02 · 03</div>
        </div>
      </div>

      <div class="hv-stack" style="display: flex; flex-direction: column; font-family: -apple-system, sans-serif; line-height: 0.85; margin: 40px 0;">
        <div class="pre" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 24px; color: var(--gray); margin-bottom: 16px; line-height: 1;">a studio of</div>
        <div class="word-1" style="font-size: min(9vw, 84px); font-weight: 900; letter-spacing: -0.04em; color: {{ component.title_color|default('var(--ink)') }};">DESIGN</div>
        <div class="word-2" style="font-size: min(9vw, 84px); font-weight: 900; letter-spacing: -0.04em; color: transparent; -webkit-text-stroke: 1px {{ component.title_color|default('var(--ink)') }};">AI</div>
        <div class="word-3" style="font-size: min(9vw, 84px); font-weight: 900; letter-spacing: -0.04em; color: {{ component.title_color|default('var(--ink)') }};">ACADEMY</div>
      </div>

      <div>
        <div class="hv-rule" style="width: 100%; height: 1px; background: var(--gray); opacity: 0.3; margin-bottom: 16px;"></div>
        <div class="hv-quote" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 20px; color: {{ component.title_color|default('var(--ink)') }}; max-width: 200px;">«النظام يتفوّق<br>على الموهبة».</div>
      </div>
    </div>
  </div>
</section>
