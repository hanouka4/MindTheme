{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="hero" style="background: {{ component.bg_color|default('var(--ink)') }}; color: {{ component.text_color|default('var(--cream)') }}; padding: 120px 40px 100px; position: relative; overflow: hidden;">
  <div class="hero-inner" style="max-width: 1180px; margin: 0 auto; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 80px; align-items: center;">
    <div style="text-align: {{ component.title_align|default('start') }};">
      <div class="eyebrow" style="font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--coral); letter-spacing: 0.25em; font-weight: 700; margin-bottom: 28px;">
        {{ component.label|default('LIVE APPLICATION  ·  4 INTENSIVE DAYS') }}
      </div>
      
      <div class="hero-rule" style="width: 60px; height: 2px; background: var(--coral); margin-bottom: 28px;
           {{ component.title_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.title_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}"></div>
      
      <h1 style="font-size: clamp(48px, 6.4vw, 92px); font-weight: 700; line-height: 1.05; margin-bottom: 18px; color: {{ component.title_color|default('var(--cream)') }};">
        {{ component.title|default('الورشة<br><span class="accent">الحضوريّة.</span>')|replace({'&lt;': '<', '&gt;': '>', '&quot;': '"'})|raw }}
      </h1>

      <p class="hero-tag" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 22px; color: var(--tan); margin-bottom: 28px; direction: ltr; text-align: left;">
        {{ component.tagline|default('Four days to build your studio from scratch, led by the MiND team in Riyadh.') }}
      </p>

      <div class="hero-quote" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 22px; line-height: 1.5; color: var(--cream); border-right: 2px solid var(--coral); padding-right: 20px; margin-bottom: 36px; max-width: 540px;">
        {{ component.quote|default('«ليس الهدف تعلّم الأداة، بل بناء الاستوديو الذي يشغّل الأداة».') }}
      </div>

      <div class="hero-meta" style="display: flex; flex-wrap: wrap; gap: 28px; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--tan); letter-spacing: 0.18em; font-weight: 700; margin-bottom: 36px;">
        <span>LOCATION <strong>RIYADH, SA</strong></span>
        <span>DURATION <strong>4 INTENSIVE DAYS</strong></span>
        <span>SEATS <strong>LIMITED BY INVITATION</strong></span>
      </div>

      <div class="cta-row" style="display: flex; gap: 14px; flex-wrap: wrap;">
        <a href="{{ component.btn_link|default('#apply') }}" class="btn btn-primary" style="background: var(--coral); color: var(--cream); padding: 18px 36px; font-weight: 700; text-decoration: none;">
          {{ component.btn_text|default('قدّم للانضمام  ←') }}
        </a>
      </div>
    </div>

    <div class="hero-poster" style="background: var(--cream); color: var(--ink); padding: 50px 44px; aspect-ratio: 1; display: flex; flex-direction: column; justify-content: space-between; position: relative;">
      <span class="hp-bracket tl" style="position: absolute; width: 26px; height: 26px; top: 16px; left: 16px; border-top: 1.5px solid var(--coral); border-left: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket tr" style="position: absolute; width: 26px; height: 26px; top: 16px; right: 16px; border-top: 1.5px solid var(--coral); border-right: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket bl" style="position: absolute; width: 26px; height: 26px; bottom: 16px; left: 16px; border-bottom: 1.5px solid var(--coral); border-left: 1.5px solid var(--coral);"></span>
      <span class="hp-bracket br" style="position: absolute; width: 26px; height: 26px; bottom: 16px; right: 16px; border-bottom: 1.5px solid var(--coral); border-right: 1.5px solid var(--coral);"></span>

      <div class="hp-top" style="display: flex; justify-content: space-between; align-items: flex-start; font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--coral); letter-spacing: 0.2em; font-weight: 700;">
        <div>STUDIO BUILD</div>
        <div>WORKSHOP</div>
      </div>

      <div class="hp-center" style="text-align: center;">
        <div class="pre" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 20px; color: var(--warm-tan); margin-bottom: 8px;">design ai</div>
        <div class="stack" style="display: flex; justify-content: center; gap: 18px; align-items: baseline;">
          <span class="num" style="font-size: clamp(120px, 14vw, 200px); font-weight: 900; color: var(--coral); line-height: 0.85; letter-spacing: -0.04em;">04</span>
        </div>
        <div class="word" style="font-family: -apple-system, sans-serif; font-size: clamp(28px, 3vw, 40px); font-weight: 300; color: var(--ink); letter-spacing: 0.04em; margin-top: 6px;">DAYS</div>
      </div>

      <div class="hp-bottom" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 16px; color: var(--ink); text-align: right; line-height: 1.4;">
        <div class="hp-rule" style="width: 30px; height: 1px; background: var(--coral); margin-bottom: 12px; margin-right: auto;"></div>
        «الحرفة تُبنى<br>بالممارسة».
      </div>
    </div>
  </div>
</section>
