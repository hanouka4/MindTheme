{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="program" id="program" style="padding: 100px 40px; background: {{ component.bg_color|default('#1A1A1A') }};">
  <div class="container" style="max-width: 1280px; margin: 0 auto;">
    
    <div class="section-label" style="font-family: 'JetBrains Mono', monospace; letter-spacing: 0.15em; margin-bottom: 24px;
         color: {{ component.label_color|default('#E85544') }}; 
         font-size: {{ component.label_size|default('11px') }}; 
         text-align: {{ component.label_align|default('start') }};">
      {{ component.label|default('PROGRAM PILLARS · ركائز البرنامج') }}
    </div>

    <h2 class="section-title" style="line-height: 1.1; margin-bottom: 24px; font-weight: 800;
         color: {{ component.title_color|default('#F7EDE3') }}; 
         font-size: {{ component.title_size|default('40px') }}; 
         text-align: {{ component.title_align|default('start') }};">
      {{ component.title|raw|default('أربع ركائز<br>تبني استوديو متكامل.') }}
    </h2>

    <p class="section-tagline" style="font-family: 'Cormorant Garamond', serif; font-style: italic; margin-bottom: 32px;
         color: {{ component.tagline_color|default('#C89469') }}; 
         font-size: {{ component.tagline_size|default('19px') }}; 
         text-align: {{ component.tagline_align|default('start') }};">
      {{ component.tagline|default('Four pillars. One operating studio.') }}
    </p>

    <div class="section-rule" style="width: 60px; height: 1px; background: var(--hairline); margin-bottom: 40px;
         {{ component.title_align == 'center' ? 'margin-left: auto; margin-right: auto;' : (component.title_align == 'end' ? 'margin-right: 0; margin-left: auto;' : '') }}"></div>
    
    <div class="pillars" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 40px; max-width: 1100px;">
      {% for pillar in component.pillars %}
        <div class="pillar" style="display: flex; gap: 24px;">
          <div class="pillar-num" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 28px; color: var(--coral); flex-shrink: 0; line-height: 1;">{{ pillar.num }}</div>
          <div class="pillar-content">
            <div class="label" style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--coral); letter-spacing: 0.15em; margin-bottom: 4px;">{{ pillar.label }}</div>
            <h3 style="font-size: 18px; margin-bottom: 8px; font-weight: 600; color: {{ component.title_color|default('#F7EDE3') }};">{{ pillar.title }}</h3>
            <p style="color: var(--tan); font-size: 14px; line-height: 1.6;">{{ pillar.desc }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
