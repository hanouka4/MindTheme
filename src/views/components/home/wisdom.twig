{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| title           | string     | Section title                  |
| rules           | array      | Philosophy rules               |
#}
<section class="wisdom">
  <div class="container" style="max-width: 1100px;">
    <div class="section-label">PHILOSOPHY  ·  المنهج</div>
    <h2 class="section-title" style="margin-bottom: 60px;">{{ title|raw|default('ثلاث قواعد<br>تحكم كل شيء.') }}</h2>
    <div class="wisdom-grid">
      {% for item in rules %}
        <div class="wisdom-item">
          <div class="wisdom-quote-mark">"</div>
          <div class="wisdom-content">
            <p>{{ item.text }}</p>
            <p>{{ item.attribution }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
