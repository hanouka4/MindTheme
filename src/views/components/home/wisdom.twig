{#
| Variable        | Type       | Description                    |
|-----------------|------------|--------------------------------|
| component       | object     | Component fields               |
#}
<section class="wisdom" style="padding: 120px 40px; border-top: 0.5px solid var(--hairline); background: {{ component.bg_color|default('#F7EDE3') }};">
  <div class="container" style="max-width: 1100px; margin: 0 auto;">
    
    <h2 class="section-title" style="line-height: 1.1; margin-bottom: 60px; font-weight: 800;
         color: {{ component.title_color|default('#1A1A1A') }}; 
         font-size: {{ component.title_size|default('40px') }}; 
         text-align: {{ component.title_align|default('start') }};">
      {{ component.title|raw|default('ثلاث قواعد<br>تحكم كل شيء.') }}
    </h2>

    <div class="wisdom-grid" style="display: grid; gap: 80px;">
      {% for item in component.rules %}
        <div class="wisdom-item" style="display: grid; grid-template-columns: 0.5fr 6fr; gap: 32px; align-items: start;">
          <div class="wisdom-quote-mark" style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 96px; line-height: 1; color: {{ component.quote_color|default('#E85544') }};">"</div>
          <div class="wisdom-content">
            <p style="font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 32px; color: var(--ink); line-height: 1.4; margin-bottom: 16px;">{{ item.text }}</p>
            <p style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--warm-tan); letter-spacing: 0.15em; font-weight: 700;">{{ item.attribution }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
